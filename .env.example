# Supabase / PostgreSQL
# Runtime connection (pooler allowed)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# Direct connection for Prisma migrations
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# App
NEXT_PUBLIC_SITE_URL="https://v03-pink.vercel.app"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"
ADMIN_SESSION_SECRET="define_a_random_secret_with_32+_chars"
ADMIN_GOOGLE_ALLOWED_EMAILS="admin1@gmail.com,admin2@gmail.com,admin3@gmail.com"

# Distributed rate limiting
# Required in production for admin login.
UPSTASH_REDIS_REST_URL="https://your-upstash-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Persistent media storage
# Required in production for uploads.
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="uploads"

# Data queries (safeDataQuery)
# In production, fail-fast is enabled by default.
# Set to "false" only for temporary degraded mode.
DATA_QUERY_FAIL_FAST="true"

# Optional seed flags
# SEED_RESET="false"
# ALLOW_PROD_SEED_RESET="false"

# Optional (local docker postgres)
POSTGRES_USER="siteeli"
POSTGRES_PASSWORD="change_me_in_env"
POSTGRES_DB="site_eli"
POSTGRES_PORT="5432"
