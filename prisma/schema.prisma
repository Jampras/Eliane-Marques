generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                      String      @id @default(cuid())
  title                   String
  slug                    String      @unique
  shortDesc               String
  longDesc                String?
  price                   Float
  type                    String
  audience                String?
  active                  Boolean     @default(true)
  coverImage              String?
  ctaMode                 String      @default("WHATSAPP")
  ctaUrl                  String?
  ctaLabel                String?
  whatsappMessageTemplate String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([type, active, createdAt(sort: Desc)])
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  published  Boolean  @default(false)
  coverImage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, createdAt(sort: Desc)])
}

model Checklist {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String?
  published   Boolean         @default(false)
  items       ChecklistItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([published, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  label       String
  linkUrl     String?
  sortOrder   Int       @default(0)
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String

  @@index([checklistId, sortOrder])
}

model SiteConfig {
  key   String @id @unique
  value String
}
