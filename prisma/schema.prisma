generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                      String      @id @default(cuid())
  title                   String
  slug                    String      @unique
  shortDesc               String
  longDesc                String?
  price                   Float
  type                    String
  audience                String?
  active                  Boolean     @default(true)
  coverImage              String?
  ctaMode                 String      @default("WHATSAPP")
  ctaUrl                  String?
  ctaLabel                String?
  featured                Boolean     @default(false)
  bestSeller              Boolean     @default(false)
  whatsappMessageTemplate String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([type, active, featured, bestSeller, createdAt(sort: Desc)])
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  published  Boolean  @default(false)
  coverImage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, createdAt(sort: Desc)])
}

model Checklist {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String?
  published   Boolean         @default(false)
  items       ChecklistItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([published, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  label       String
  linkUrl     String?
  sortOrder   Int       @default(0)
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String

  @@index([checklistId, sortOrder])
}

model SiteConfig {
  key   String @id @unique
  value String
}

model AnalyticsEvent {
  id           String   @id @default(cuid())
  name         String
  source       String
  path         String?
  productId    String?
  productSlug  String?
  productTitle String?
  destination  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([name, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([productSlug, createdAt(sort: Desc)])
}

model AnalyticsDailyAggregate {
  dayBucket       DateTime
  name            String
  source          String
  pathKey         String   @default("")
  productSlugKey  String   @default("")
  productTitleKey String   @default("")
  destinationKey  String   @default("")
  count           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@id([dayBucket, name, source, pathKey, productSlugKey, destinationKey])
  @@index([dayBucket(sort: Desc)])
  @@index([name, dayBucket(sort: Desc)])
  @@index([source, dayBucket(sort: Desc)])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  source    String
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  @@index([status, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
}

model AboutPage {
  id                      String                @id @default(cuid())
  singletonKey            String                @unique @default("main")
  heroTitle               String
  heroSubtitle            String?
  introTitle              String?
  introBody               String?
  manifestoTitle          String?
  manifestoBody           String?
  heroImage               String?
  ctaMode                 String                @default("WHATSAPP")
  ctaUrl                  String?
  ctaLabel                String?
  whatsappMessageTemplate String?
  milestones              AboutMilestone[]
  specializations         AboutSpecialization[]
  credentials             AboutCredential[]
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
}

model HomePage {
  id                     String                @id @default(cuid())
  singletonKey           String                @unique @default("main")
  heroEyebrow            String?
  heroPanelImage         String?
  heroTitle              String
  heroSubtitle           String?
  heroPrimaryCtaLabel    String?
  heroSecondaryCtaLabel  String?
  heroTrustText          String?
  audienceTitle          String?
  audienceSubtitle       String?
  valueTitle             String?
  valueSubtitle          String?
  valueCtaLabel          String?
  methodTitle            String?
  methodSubtitle         String?
  methodCtaLabel         String?
  faqTitle               String?
  faqSubtitle            String?
  finalCtaTitle          String?
  finalCtaSubtitle       String?
  finalCtaScarcityText   String?
  finalCtaLabel          String?
  finalWhatsappMessage   String?
  audienceItems          HomeAudienceItem[]
  valueItems             HomeValueItem[]
  methodSteps            HomeMethodStep[]
  faqItems               HomeFaqItem[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model AboutMilestone {
  id          String    @id @default(cuid())
  title       String
  description String
  year        String?
  sortOrder   Int       @default(0)
  aboutPage   AboutPage @relation(fields: [aboutPageId], references: [id], onDelete: Cascade)
  aboutPageId String

  @@index([aboutPageId, sortOrder])
}

model AboutSpecialization {
  id          String    @id @default(cuid())
  title       String
  description String
  sortOrder   Int       @default(0)
  aboutPage   AboutPage @relation(fields: [aboutPageId], references: [id], onDelete: Cascade)
  aboutPageId String

  @@index([aboutPageId, sortOrder])
}

model AboutCredential {
  id          String    @id @default(cuid())
  title       String
  issuer      String?
  year        String?
  imageUrl    String?
  kind        String    @default("CERTIFICATE")
  sortOrder   Int       @default(0)
  aboutPage   AboutPage @relation(fields: [aboutPageId], references: [id], onDelete: Cascade)
  aboutPageId String

  @@index([aboutPageId, sortOrder])
  @@index([kind, sortOrder])
}

model HomeAudienceItem {
  id         String   @id @default(cuid())
  title      String
  description String
  icon       String?
  imageUrl   String?
  sortOrder  Int      @default(0)
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)
  homePageId String

  @@index([homePageId, sortOrder])
}

model HomeValueItem {
  id          String   @id @default(cuid())
  badge       String?
  title       String
  bullets     Json
  tone        String   @default("NEUTRAL")
  imageUrl    String?
  sortOrder   Int      @default(0)
  homePage    HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)
  homePageId  String

  @@index([homePageId, sortOrder])
}

model HomeMethodStep {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  sortOrder   Int      @default(0)
  homePage    HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)
  homePageId  String

  @@index([homePageId, sortOrder])
}

model HomeFaqItem {
  id         String   @id @default(cuid())
  question   String
  answer     String
  sortOrder  Int      @default(0)
  homePage   HomePage @relation(fields: [homePageId], references: [id], onDelete: Cascade)
  homePageId String

  @@index([homePageId, sortOrder])
}
